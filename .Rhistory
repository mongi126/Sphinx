# 查找 tinytex 安装路径
tinytex_root <- tinytex::tinytex_root()
print(tinytex_root)
# 查找 pdflatex.exe 的位置
tex_root <- "C:/Users/17649/AppData/Roaming/TinyTeX"
# 检查可能的 bin 目录
bin_candidates <- c(
file.path(tex_root, "bin", "windows"),
file.path(tex_root, "bin", "win32"),
file.path(tex_root, "bin", "x86_64-w64-mingw32"),
file.path(tex_root, "texmf-dist", "scripts")
)
cat("查找 pdflatex.exe...\n")
for (bin_path in bin_candidates) {
pdflatex_file <- file.path(bin_path, "pdflatex.exe")
if (file.exists(pdflatex_file)) {
cat("✅ 找到 pdflatex.exe 在:", bin_path, "\n")
actual_bin <- bin_path
break
}
}
# 将找到的路径添加到系统 PATH
if (exists("actual_bin")) {
# 临时添加到当前 R 会话
Sys.setenv(PATH = paste(actual_bin, Sys.getenv("PATH"), sep = ";"))
# 验证
cat("\n当前 pdflatex 路径:", Sys.which("pdflatex"), "\n")
# 测试运行
test_cmd <- try(system2("pdflatex", "--version", stdout = TRUE, stderr = TRUE))
if (length(test_cmd) > 0 && !inherits(test_cmd, "try-error")) {
cat("\n✅ pdflatex 可以正常工作！\n")
print(head(test_cmd, 3))
}
}
