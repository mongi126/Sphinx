# "#E5D2DD"           "#53A85F"           "#F1BB72"           "#F3B1A0"
# Endothelial                GC_B       M2_Macrophage    Proliferating_DC
# "#D6E7A3"           "#57C3F3"           "#476D87"           "#E95C59"
# Proliferating_Tumor                   T               Tumor
# "#E59CC4"           "#AB3282"           "#23452F"
celltype_colors <- c(
"B" = "#E5D2DD",
"CAF" = "#53A85F",
"DC" = "#F1BB72",
"EMT_like_Tumor" = "#F3B1A0",
"Endothelial" = "#D6E7A3",
"GC_B" = "#57C3F3",
"M2_Macrophage" = "#476D87",
"Proliferating_DC" = "#E95C59",
"Proliferating_Tumor" = "#E59CC4",
"T" = "#AB3282",
"Tumor" = "#23452F"
)
legend_df <- data.frame(
celltype = names(celltype_colors),
x = 1,
y = seq_along(celltype_colors)
)
p <- ggplot(legend_df, aes(x = x, y = y, color = celltype)) +
geom_point(size = 6) +
scale_color_manual(values = celltype_colors) +
theme_void() +
guides(color = guide_legend(nrow = 1)) +   # 单行排列
theme(
legend.position = "bottom",
legend.direction = "horizontal",
legend.title = element_blank(),
legend.text = element_text(size = 12)
)
ggsave("celltype_legend.pdf", p, width = 15, height = 5)
ggsave("celltype_legend.png", p, width = 15, height = 5,dpi = 300)
