# 检查所有 Rd 文件中的特殊字符
rd_files <- list.files("man", pattern = "\\.Rd$", full.names = TRUE)
check_rd_special_chars <- function(file) {
content <- readLines(file, warn = FALSE)
issues <- list()
# 检查未转义的特殊字符
if (any(grepl("(?<!\\\\)[&%$#_{}]", content, perl = TRUE))) {
issues$special_chars <- "发现未转义的特殊字符 (& % $ # _ { })"
}
# 检查不配对的括号
open_braces <- sum(grepl("\\{", content))
close_braces <- sum(grepl("\\}", content))
if (open_braces != close_braces) {
issues$braces <- paste("括号不配对: {", open_braces, "vs }", close_braces)
}
# 检查非 ASCII 字符
if (any(grepl("[^\x01-\x7F]", content, perl = TRUE))) {
issues$non_ascii <- "发现非 ASCII 字符，请使用 \\uxxxx 转义"
}
return(issues)
}
# 检查所有 Rd 文件
for (file in rd_files) {
issues <- check_rd_special_chars(file)
if (length(issues) > 0) {
cat("\n文件:", basename(file), "\n")
print(issues)
}
}
# 检查所有 Rd 文件
for (file in rd_files) {
issues <- check_rd_special_chars(file)
if (length(issues) > 0) {
cat("\n文件:", basename(file), "\n")
print(issues)
}
}
# 检查所有 Rd 文件
for (file in rd_files) {
issues <- check_rd_special_chars(file)
if (length(issues) > 0) {
cat("\n文件:", basename(file), "\n")
print(issues)
}
}
# === 批量修复 Rd 文件中的特殊字符 ===
fix_rd_special_chars <- function() {
rd_files <- list.files("man", pattern = "\\.Rd$", full.names = TRUE)
fixed_count <- 0
for (file in rd_files) {
content <- readLines(file, warn = FALSE)
original_content <- content
# 修复常见的特殊字符（保留已有的转义）
content <- gsub("(?<!\\\\)&(?!\\w+;)", "\\\\&", content, perl = TRUE)
content <- gsub("(?<!\\\\)%", "\\\\%", content, perl = TRUE)
content <- gsub("(?<!\\\\)#", "\\\\#", content, perl = TRUE)
content <- gsub("(?<!\\\\)_", "\\\\_", content, perl = TRUE)
content <- gsub("(?<!\\\\)\\$(?!\\d)", "\\\\$", content, perl = TRUE)
# 注意：{ 和 } 在 Rd 文件中通常是正常的，不需要转义
# 只有当它们作为普通文本出现时才需要转义
# 如果内容有变化，写回文件
if (!identical(original_content, content)) {
writeLines(content, file)
fixed_count <- fixed_count + 1
cat("✅ 已修复:", basename(file), "\n")
}
}
cat("\n=== 修复完成 ===\n")
cat("共修复", fixed_count, "个文件\n")
}
# 运行修复
fix_rd_special_chars()
