# 修复namespace
rd_files <- list.files("man", pattern = "\\.Rd$", full.names = TRUE)
for (file in rd_files) {
content <- readLines(file)
# 找到 \name 行的位置
name_idx <- grep("^\\\\name\\{", content)
if (length(name_idx) > 0) {
# 确保 \name 只包含简单的函数名，格式为 \name{function_name}
func_name <- gsub("\\.Rd$", "", basename(file))
content[name_idx[1]] <- paste0("\\name{", func_name, "}")
# 确保文件以正确的部分开始
# Rd 文件必须在 \name 后有 \alias 和 \title
if (!any(grepl("^\\\\alias\\{", content))) {
alias_line <- paste0("\\alias{", func_name, "}")
content <- append(content, alias_line, after = name_idx[1])
}
if (!any(grepl("^\\\\title\\{", content))) {
title_line <- paste0("\\title{", func_name, "}")
content <- append(content, title_line, after = name_idx[1] + 1)
}
}
writeLines(content, file)
}
cat("Rd files fixed\n")
