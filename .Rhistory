# 找出所有 R 文件中使用的 Suggests 包函数
r_files <- list.files("R", pattern = "\\.R$", full.names = TRUE)
suggests_pkgs <- c("Matrix", "gridExtra", "progress", "scattermore",
"viridisLite", "Seurat", "methods")
for (file in r_files) {
content <- readLines(file)
for (pkg in suggests_pkgs) {
# 查找直接调用（没有 pkg:: 前缀）
pattern <- paste0("(?<!", pkg, "::)\\b(", pkg, "::)?[a-zA-Z_]+\\(")
matches <- grepl(pattern, content, perl = TRUE)
if (any(matches)) {
cat("\n文件:", basename(file), "可能直接使用了", pkg, "的函数\n")
cat("行:", which(matches), "\n")
}
}
}
