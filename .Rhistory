rd_files <- list.files("man", pattern = "\\.Rd$", full.names = TRUE)
rd_files
for (file in rd_files) {
content <- readLines(file)
modified <- FALSE
for (i in seq_along(content)) {
line <- content[i]
# 跳过代码块
if (grepl("^#|\\\\code\\{", line)) next
# 转义特殊字符（但保留已有的转义）
line <- gsub("(?<!\\\\)%", "\\\\%", line, perl = TRUE)
line <- gsub("(?<!\\\\)&", "\\\\&", line, perl = TRUE)
line <- gsub("(?<!\\\\)_", "\\\\_", line, perl = TRUE)
line <- gsub("(?<!\\\\)#", "\\\\#", line, perl = TRUE)
line <- gsub("(?<!\\\\)\\$", "\\\\$", line, perl = TRUE)
line <- gsub("(?<!\\\\)\\{", "\\\\{", line, perl = TRUE)
line <- gsub("(?<!\\\\)\\}", "\\\\}", line, perl = TRUE)
if (line != content[i]) {
content[i] <- line
modified <- TRUE
}
}
if (modified) writeLines(content, file)
}
